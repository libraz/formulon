{
  "suite": "offset_indirect_probes",
  "description": "Mac Excel 365 (ja-JP) probe for two narrow questions that cannot be inferred from existing oracle suites:\n\n  1. OFFSET with negative height/width: IronCalc rejects with #VALUE!.\n     The IronCalc workbook itself has the comment \"Negative values in\n     width/height produce #VALUE!\", but the probe pins Mac's actual\n     behavior to confirm — Formulon currently returns 0 (a silent\n     fall-through) and we need to know whether to fix the validator\n     or list this as a divergence.\n\n  2. ROW / COLUMN of INDIRECT pointing to a non-existent sheet:\n     IronCalc returns the row/column index of the referenced cell\n     (5 / 4 for \"OTHER!D5\") on the theory that ROW/COLUMN only\n     extract the index without resolving the value, even if the\n     sheet is missing. Formulon currently propagates #REF! from\n     INDIRECT. Mac's truth becomes the reference.\n\nSpill / IIE behavior (the other 11 IronCalc failures in this cluster) is already settled by tests/oracle/cases/implicit_intersection.yaml, so this probe focuses only on the two open questions above.\n",
  "environment": {
    "excel_version": "16.108.1",
    "excel_locale": "ja-JP",
    "date1904": false,
    "iterative": false,
    "generated_at": "2026-04-26T01:33:41Z"
  },
  "tolerance": {
    "abs": 0.0,
    "rel": 0.0
  },
  "cases": [
    {
      "id": "offset_neg_height",
      "formula": "=OFFSET(A1, 0, 0, -10, 1)",
      "setup": {
        "A1": {
          "kind": "number",
          "value": 5.0
        }
      },
      "expect": {
        "kind": "error",
        "code": "#REF!"
      }
    },
    {
      "id": "offset_neg_width",
      "formula": "=OFFSET(A1, 0, 0, 1, -2)",
      "setup": {
        "A1": {
          "kind": "number",
          "value": 5.0
        }
      },
      "expect": {
        "kind": "error",
        "code": "#REF!"
      }
    },
    {
      "id": "offset_zero_height",
      "formula": "=OFFSET(A1, 0, 0, 0, 1)",
      "setup": {
        "A1": {
          "kind": "number",
          "value": 5.0
        }
      },
      "expect": {
        "kind": "error",
        "code": "#REF!"
      }
    },
    {
      "id": "offset_zero_width",
      "formula": "=OFFSET(A1, 0, 0, 1, 0)",
      "setup": {
        "A1": {
          "kind": "number",
          "value": 5.0
        }
      },
      "expect": {
        "kind": "error",
        "code": "#REF!"
      }
    },
    {
      "id": "offset_neg_height_in_bounds",
      "formula": "=OFFSET(C5, 2, 2, -2, 1)",
      "setup": {
        "E6": {
          "kind": "number",
          "value": 60.0
        },
        "E7": {
          "kind": "number",
          "value": 70.0
        }
      },
      "expect": {
        "kind": "number",
        "value": 60.0
      }
    },
    {
      "id": "offset_neg_width_in_bounds",
      "formula": "=OFFSET(C5, 2, 2, 1, -2)",
      "setup": {
        "D7": {
          "kind": "number",
          "value": 47.0
        },
        "E7": {
          "kind": "number",
          "value": 70.0
        }
      },
      "expect": {
        "kind": "number",
        "value": 47.0
      }
    },
    {
      "id": "row_indirect_missing_sheet_string",
      "formula": "=ROW(INDIRECT(\"OTHER!D5\"))",
      "setup": {},
      "expect": {
        "kind": "error",
        "code": "#REF!"
      }
    },
    {
      "id": "column_indirect_missing_sheet_string",
      "formula": "=COLUMN(INDIRECT(\"OTHER!D5\"))",
      "setup": {},
      "expect": {
        "kind": "error",
        "code": "#REF!"
      }
    },
    {
      "id": "row_indirect_missing_sheet_via_cell",
      "formula": "=ROW(INDIRECT(A1))",
      "setup": {
        "A1": {
          "kind": "text",
          "value": "OTHER!D5"
        }
      },
      "expect": {
        "kind": "error",
        "code": "#REF!"
      }
    },
    {
      "id": "column_indirect_missing_sheet_via_cell",
      "formula": "=COLUMN(INDIRECT(A1))",
      "setup": {
        "A1": {
          "kind": "text",
          "value": "OTHER!D5"
        }
      },
      "expect": {
        "kind": "error",
        "code": "#REF!"
      }
    },
    {
      "id": "row_indirect_same_sheet",
      "formula": "=ROW(INDIRECT(\"D5\"))",
      "setup": {},
      "expect": {
        "kind": "number",
        "value": 5.0
      }
    },
    {
      "id": "column_indirect_same_sheet",
      "formula": "=COLUMN(INDIRECT(\"D5\"))",
      "setup": {},
      "expect": {
        "kind": "number",
        "value": 4.0
      }
    }
  ]
}
