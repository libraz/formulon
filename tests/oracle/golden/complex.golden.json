{
  "suite": "complex",
  "description": "Excel's complex-number family: COMPLEX + the 24 IM* functions. Cases focus on the formatting rules (pure real, pure imag, +/-1 coefficient elision, alternate 'j' suffix), the arithmetic core (IMSUM / IMSUB / IMPRODUCT / IMDIV / IMPOWER) including mixed-suffix error cases, and exponential / logarithmic / root operations where floating-point drift is most likely. Trigonometric and hyperbolic variants are exercised at stable points (z=0, pure real) to keep goldens robust.\n",
  "environment": {
    "excel_version": "16.108.1",
    "excel_locale": "ja-JP",
    "date1904": false,
    "iterative": false,
    "generated_at": "2026-04-26T02:36:25Z"
  },
  "tolerance": {
    "abs": 1e-05,
    "rel": 1e-05
  },
  "cases": [
    {
      "id": "complex_full_default_suffix",
      "formula": "=COMPLEX(3,4)",
      "setup": {},
      "expect": {
        "kind": "text",
        "value": "3+4i"
      }
    },
    {
      "id": "complex_full_j_suffix",
      "formula": "=COMPLEX(3,4,\"j\")",
      "setup": {},
      "expect": {
        "kind": "text",
        "value": "3+4j"
      }
    },
    {
      "id": "complex_pure_imag_plus_one",
      "formula": "=COMPLEX(0,1)",
      "setup": {},
      "expect": {
        "kind": "text",
        "value": "i"
      }
    },
    {
      "id": "complex_pure_imag_minus_one",
      "formula": "=COMPLEX(0,-1)",
      "setup": {},
      "expect": {
        "kind": "text",
        "value": "-i"
      }
    },
    {
      "id": "complex_pure_imag_five",
      "formula": "=COMPLEX(0,5)",
      "setup": {},
      "expect": {
        "kind": "text",
        "value": "5i"
      }
    },
    {
      "id": "complex_pure_real",
      "formula": "=COMPLEX(3,0)",
      "setup": {},
      "expect": {
        "kind": "text",
        "value": "3"
      }
    },
    {
      "id": "complex_full_plus_one_imag",
      "formula": "=COMPLEX(3,1)",
      "setup": {},
      "expect": {
        "kind": "text",
        "value": "3+i"
      }
    },
    {
      "id": "complex_full_minus_one_imag",
      "formula": "=COMPLEX(3,-1)",
      "setup": {},
      "expect": {
        "kind": "text",
        "value": "3-i"
      }
    },
    {
      "id": "complex_invalid_suffix_is_value",
      "formula": "=COMPLEX(3,4,\"x\")",
      "setup": {},
      "expect": {
        "kind": "error",
        "code": "#VALUE!"
      }
    },
    {
      "id": "imabs_three_four",
      "formula": "=IMABS(\"3+4i\")",
      "setup": {},
      "expect": {
        "kind": "number",
        "value": 5.0
      }
    },
    {
      "id": "imreal_three_four",
      "formula": "=IMREAL(\"3+4i\")",
      "setup": {},
      "expect": {
        "kind": "number",
        "value": 3.0
      }
    },
    {
      "id": "imaginary_three_four",
      "formula": "=IMAGINARY(\"3+4i\")",
      "setup": {},
      "expect": {
        "kind": "number",
        "value": 4.0
      }
    },
    {
      "id": "imconjugate_three_four",
      "formula": "=IMCONJUGATE(\"3+4i\")",
      "setup": {},
      "expect": {
        "kind": "text",
        "value": "3-4i"
      }
    },
    {
      "id": "imargument_three_four",
      "formula": "=IMARGUMENT(\"3+4i\")",
      "setup": {},
      "expect": {
        "kind": "number",
        "value": 0.9272952180016122
      }
    },
    {
      "id": "imargument_zero_is_div0",
      "formula": "=IMARGUMENT(\"0\")",
      "setup": {},
      "expect": {
        "kind": "error",
        "code": "#DIV/0!"
      }
    },
    {
      "id": "imsum_two_args",
      "formula": "=IMSUM(\"1+i\",\"2+3i\")",
      "setup": {},
      "expect": {
        "kind": "text",
        "value": "3+4i"
      }
    },
