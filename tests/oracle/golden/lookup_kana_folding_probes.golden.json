{
  "suite": "lookup_kana_folding_probes",
  "description": "Mac Excel ja-JP COUNTIF / SUMIF text equality folds kana variants (hiragana<->katakana, half<->full kana with voicing composition, full<->half ASCII). The criteria.cpp matcher implements that fold. Lookup functions (VLOOKUP, HLOOKUP, MATCH, XLOOKUP, XMATCH) use separate text-equality paths, so it is unclear whether Mac applies the same fold there. These probes pin Mac's behaviour empirically before deciding whether the lookup family needs the same fix.\n",
  "environment": {
    "excel_version": "16.108.1",
    "excel_locale": "ja-JP",
    "date1904": false,
    "iterative": false,
    "generated_at": "2026-04-26T22:24:23Z"
  },
  "tolerance": {
    "abs": 0.0,
    "rel": 0.0
  },
  "cases": [
    {
      "id": "match_exact_hira_eq_kata",
      "formula": "=MATCH(\"あ\", A1:A3, 0)",
      "setup": {
        "A1": {
          "kind": "text",
          "value": "ア"
        },
        "A2": {
          "kind": "text",
          "value": "い"
        },
        "A3": {
          "kind": "text",
          "value": "う"
        }
      },
      "expect": {
        "kind": "number",
        "value": 1.0
      }
    },
