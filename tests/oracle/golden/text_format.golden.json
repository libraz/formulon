{
  "suite": "text_format",
  "description": "TEXT format-string engine (number + date/time formatting)",
  "environment": {
    "excel_version": "16.108.1",
    "excel_locale": "ja-JP",
    "date1904": false,
    "iterative": false,
    "generated_at": "2026-04-23T08:03:23Z"
  },
  "tolerance": {
    "abs": 0.0,
    "rel": 0.0
  },
  "cases": [
    {
      "id": "text_integer_zeropad",
      "formula": "=TEXT(5, \"000\")",
      "setup": {},
      "expect": {
        "kind": "text",
        "value": "005"
      }
    },
    {
      "id": "text_integer_hash_trims_leading",
      "formula": "=TEXT(5, \"###\")",
      "setup": {},
      "expect": {
        "kind": "text",
        "value": "5"
      }
    },
    {
      "id": "text_integer_negative_zeropad",
      "formula": "=TEXT(-5, \"000\")",
      "setup": {},
      "expect": {
        "kind": "text",
        "value": "-005"
      }
    },
    {
      "id": "text_integer_zero_with_zero_fmt",
      "formula": "=TEXT(0, \"000\")",
      "setup": {},
      "expect": {
        "kind": "text",
        "value": "000"
      }
    },
    {
      "id": "text_thousands_basic",
      "formula": "=TEXT(1234567, \"#,##0\")",
      "setup": {},
      "expect": {
        "kind": "text",
        "value": "1,234,567"
      }
    },
    {
      "id": "text_thousands_small_value",
      "formula": "=TEXT(12, \"#,##0\")",
      "setup": {},
      "expect": {
        "kind": "text",
        "value": "12"
      }
    },
    {
      "id": "text_thousands_with_decimals",
      "formula": "=TEXT(1234.5, \"#,##0.00\")",
      "setup": {},
      "expect": {
        "kind": "text",
        "value": "1,234.50"
      }
    },
    {
      "id": "text_thousands_negative",
      "formula": "=TEXT(-1234, \"#,##0\")",
      "setup": {},
      "expect": {
        "kind": "text",
        "value": "-1,234"
      }
    },
    {
      "id": "text_decimal_two",
      "formula": "=TEXT(3.14159, \"0.00\")",
      "setup": {},
      "expect": {
        "kind": "text",
        "value": "3.14"
      }
    },
    {
      "id": "text_decimal_round_up",
      "formula": "=TEXT(3.145, \"0.00\")",
