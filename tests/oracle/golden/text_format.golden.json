    {
      "id": "text_decimal_hash_trims_trailing",
      "formula": "=TEXT(1.5, \"#.##\")",
      "setup": {},
      "expect": {
        "kind": "text",
        "value": "1.5"
      }
    },
    {
      "id": "text_decimal_negative",
      "formula": "=TEXT(-1.5, \"0.00\")",
      "setup": {},
      "expect": {
        "kind": "text",
        "value": "-1.50"
      }
    },
    {
      "id": "text_percent_basic",
      "formula": "=TEXT(0.5, \"0%\")",
