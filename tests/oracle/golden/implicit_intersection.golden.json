      "setup": {
        "A1": {
          "kind": "number",
          "value": 1.234
        },
        "B1": {
          "kind": "number",
          "value": 2.345
        },
        "C1": {
          "kind": "number",
          "value": 3.456
        }
      },
      "expect": {
        "kind": "number",
        "value": 1.23
      }
    },
    {
      "id": "round_col_range_row_included",
      "formula": "=ROUND(A1:A5, 2)",
      "setup": {
        "A1": {
          "kind": "number",
          "value": 1.234
