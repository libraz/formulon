{
  "suite": "datevalue_timevalue",
  "description": "DATEVALUE / TIMEVALUE text-to-serial parsing (ISO / slash / kanji forms, AM-PM, embedded date-time)",
  "environment": {
    "excel_version": "16.108.1",
    "excel_locale": "ja-JP",
    "date1904": false,
    "iterative": false,
    "generated_at": "2026-04-23T06:16:49Z"
  },
  "tolerance": {
    "abs": 1e-10,
    "rel": 1e-10
  },
  "cases": [
    {
      "id": "datevalue_iso_dash",
      "formula": "=DATEVALUE(\"2024-03-15\")",
      "setup": {},
      "expect": {
        "kind": "number",
        "value": 45366.0
      }
    },
    {
      "id": "datevalue_iso_dash_single_digit",
      "formula": "=DATEVALUE(\"2024-3-5\")",
      "setup": {},
      "expect": {
        "kind": "number",
        "value": 45356.0
      }
    },
    {
      "id": "datevalue_iso_with_t_separator",
      "formula": "=DATEVALUE(\"2024-03-15T00:00:00\")",
      "setup": {},
      "expect": {
        "kind": "error",
        "code": "#VALUE!"
      }
    },
    {
      "id": "datevalue_iso_with_space_time",
      "formula": "=DATEVALUE(\"2024-03-15 13:30\")",
      "setup": {},
      "expect": {
        "kind": "number",
        "value": 45366.0
      }
    },
    {
      "id": "datevalue_slash",
      "formula": "=DATEVALUE(\"2024/3/15\")",
      "setup": {},
      "expect": {
        "kind": "number",
        "value": 45366.0
      }
    },
    {
      "id": "datevalue_slash_padded",
      "formula": "=DATEVALUE(\"2024/03/15\")",
      "setup": {},
      "expect": {
        "kind": "number",
        "value": 45366.0
      }
    },
    {
      "id": "datevalue_kanji_with_terminator",
      "formula": "=DATEVALUE(\"2024年3月15日\")",
      "setup": {},
      "expect": {
        "kind": "number",
        "value": 45366.0
      }
    },
    {
      "id": "datevalue_kanji_padded_no_terminator",
      "formula": "=DATEVALUE(\"2024年03月15\")",
      "setup": {},
      "expect": {
        "kind": "error",
        "code": "#VALUE!"
      }
    },
    {
      "id": "datevalue_leading_whitespace",
      "formula": "=DATEVALUE(\"   2024-03-15\")",
      "setup": {},
      "expect": {
        "kind": "number",
        "value": 45366.0
      }
    },
    {
      "id": "datevalue_trailing_whitespace",
      "formula": "=DATEVALUE(\"2024-03-15   \")",
      "setup": {},
      "expect": {
        "kind": "number",
        "value": 45366.0
      }
    },
    {
      "id": "datevalue_fullwidth_space_trimmed",
      "formula": "=DATEVALUE(\"　2024-03-15　\")",
      "setup": {},
      "expect": {
        "kind": "error",
        "code": "#VALUE!"
      }
    },
    {
      "id": "datevalue_two_digit_year_2020s",
      "formula": "=DATEVALUE(\"29-03-15\")",
      "setup": {},
      "expect": {
        "kind": "number",
        "value": 47192.0
      }
    },
    {
      "id": "datevalue_two_digit_year_1990s",
      "formula": "=DATEVALUE(\"95-07-04\")",
      "setup": {},
      "expect": {
        "kind": "number",
        "value": 34884.0
      }
    },
    {
      "id": "datevalue_real_leap_day",
      "formula": "=DATEVALUE(\"2024-02-29\")",
      "setup": {},
      "expect": {
        "kind": "number",
        "value": 45351.0
      }
    },
    {
      "id": "datevalue_non_leap_feb_29_is_value",
      "formula": "=DATEVALUE(\"2023-02-29\")",
      "setup": {},
      "expect": {
        "kind": "error",
        "code": "#VALUE!"
      }
    },
    {
      "id": "datevalue_empty_string_is_value",
      "formula": "=DATEVALUE(\"\")",
      "setup": {},
      "expect": {
        "kind": "error",
        "code": "#VALUE!"
      }
    },
    {
      "id": "datevalue_whitespace_only_is_value",
      "formula": "=DATEVALUE(\"   \")",
      "setup": {},
      "expect": {
        "kind": "error",
        "code": "#VALUE!"
      }
    },
    {
      "id": "datevalue_malformed_is_value",
      "formula": "=DATEVALUE(\"hello world\")",
      "setup": {},
      "expect": {
        "kind": "error",
        "code": "#VALUE!"
      }
    },
    {
      "id": "datevalue_month_out_of_range_is_value",
      "formula": "=DATEVALUE(\"2024-13-01\")",
      "setup": {},
      "expect": {
        "kind": "error",
        "code": "#VALUE!"
      }
    },
    {
      "id": "datevalue_day_out_of_range_is_value",
      "formula": "=DATEVALUE(\"2024-02-30\")",
      "setup": {},
      "expect": {
        "kind": "error",
        "code": "#VALUE!"
      }
    },
    {
      "id": "datevalue_boolean_coerces_and_fails",
      "formula": "=DATEVALUE(TRUE)",
      "setup": {},
      "expect": {
        "kind": "error",
        "code": "#VALUE!"
      }
    },
    {
      "id": "datevalue_number_coerces_and_fails",
      "formula": "=DATEVALUE(42)",
      "setup": {},
      "expect": {
        "kind": "error",
        "code": "#VALUE!"
      }
    },
    {
      "id": "datevalue_agrees_with_date",
      "formula": "=DATEVALUE(\"2026-04-23\")-DATE(2026,4,23)",
      "setup": {},
      "expect": {
        "kind": "number",
        "value": 0.0
      }
    },
    {
      "id": "timevalue_hours_minutes",
      "formula": "=TIMEVALUE(\"13:30\")",
      "setup": {},
      "expect": {
        "kind": "number",
        "value": 0.5625
      }
    },
    {
      "id": "timevalue_midnight",
      "formula": "=TIMEVALUE(\"00:00\")",
