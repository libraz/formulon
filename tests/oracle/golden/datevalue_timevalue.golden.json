    },
    {
      "id": "timevalue_hours_above_24_wrap",
      "formula": "=TIMEVALUE(\"25:00\")",
      "setup": {},
      "expect": {
        "kind": "number",
        "value": 0.04166666666666674
      }
    },
    {
      "id": "timevalue_embedded_in_date",
      "formula": "=TIMEVALUE(\"2024-03-15 13:30\")",
      "setup": {},
      "expect": {
        "kind": "number",
        "value": 0.5625
      }
    },
    {
      "id": "timevalue_iso_t_separator",
      "formula": "=TIMEVALUE(\"2024-03-15T06:00:00\")",
      "setup": {},
      "expect": {
        "kind": "error",
        "code": "#VALUE!"
      }
    },
    {
      "id": "timevalue_leading_whitespace",
      "formula": "=TIMEVALUE(\"   13:30\")",
      "setup": {},
      "expect": {
        "kind": "number",
        "value": 0.5625
      }
    },
    {
      "id": "timevalue_trailing_fullwidth_space",
      "formula": "=TIMEVALUE(\"13:30　\")",
      "setup": {},
      "expect": {
        "kind": "number",
        "value": 0.5625
      }
    },
    {
      "id": "timevalue_empty_string_is_value",
