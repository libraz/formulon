    {
      "id": "timevalue_one_thirty_pm",
      "formula": "=TIMEVALUE(\"1:30 PM\")",
      "setup": {},
      "expect": {
        "kind": "number",
        "value": 0.5625
      }
    },
    {
      "id": "timevalue_twelve_am_is_midnight",
      "formula": "=TIMEVALUE(\"12:00 AM\")",
