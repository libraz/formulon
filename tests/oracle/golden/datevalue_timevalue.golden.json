    },
    {
      "id": "timevalue_twelve_pm_is_noon",
      "formula": "=TIMEVALUE(\"12:00 PM\")",
      "setup": {},
      "expect": {
        "kind": "number",
        "value": 0.5
      }
    },
    {
      "id": "timevalue_lowercase_ampm",
      "formula": "=TIMEVALUE(\"1:30 pm\")",
      "setup": {},
      "expect": {
        "kind": "number",
        "value": 0.5625
      }
    },
    {
      "id": "timevalue_no_space_before_ampm",
      "formula": "=TIMEVALUE(\"1:30PM\")",
      "setup": {},
      "expect": {
        "kind": "error",
        "code": "#VALUE!"
