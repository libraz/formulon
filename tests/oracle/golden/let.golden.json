        },
        "A2": {
          "kind": "text",
          "value": "x"
        },
        "A3": {
          "kind": "number",
          "value": 3.0
        }
      },
      "skipped": "LET range binding collapses to scalar before COUNT iterates."
    },
    {
      "id": "range_binding_arithmetic_at_anchor",
      "formula": "=LET(r, A1:A3, r+1)",
      "setup": {
        "A1": {
          "kind": "number",
          "value": 10.0
        },
        "A2": {
          "kind": "number",
