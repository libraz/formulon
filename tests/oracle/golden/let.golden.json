      "expect": {
        "kind": "number",
        "value": 1.0
      }
    },
    {
      "id": "binding_error_catchable",
      "formula": "=LET(x, 1/0, IFERROR(x, 99))",
      "setup": {},
      "expect": {
        "kind": "number",
        "value": 99.0
      }
    },
    {
      "id": "binding_error_uncaught_propagates",
      "formula": "=LET(x, 1/0, x+1)",
      "setup": {},
      "expect": {
        "kind": "error",
        "code": "#DIV/0!"
      }
    },
    {
      "id": "range_binding_sum",
      "formula": "=LET(r, A1:A3, SUM(r))",
      "setup": {
        "A1": {
          "kind": "number",
