      "setup": {},
      "expect": {
        "kind": "error",
        "code": "#NUM!"
      }
    },
    {
      "id": "floor_pos_num_neg_sig_large",
      "formula": "=FLOOR(10,-7)",
      "setup": {},
      "expect": {
        "kind": "error",
        "code": "#NUM!"
      }
    },
    {
      "id": "floor_pos_num_neg_sig_tiny",
      "formula": "=FLOOR(10,-1e-12)",
      "setup": {},
      "expect": {
        "kind": "error",
        "code": "#NUM!"
      }
    },
    {
      "id": "ceiling_pos_num_neg_sig_simple",
