      "id": "floor_pos_num_neg_sig_simple",
      "formula": "=FLOOR(10,-1)",
      "setup": {},
      "expect": {
        "kind": "error",
        "code": "#NUM!"
      }
    },
    {
      "id": "floor_pos_num_neg_sig_fraction",
      "formula": "=FLOOR(7.1,-0.1)",
      "setup": {},
      "expect": {
        "kind": "error",
        "code": "#NUM!"
      }
    },
    {
