      "setup": {},
      "expect": {
        "kind": "number",
        "value": 0.0
      }
    },
    {
      "id": "lcm_three_zero_scalars",
      "formula": "=LCM(0,0,0)",
      "setup": {},
      "expect": {
        "kind": "number",
        "value": 0.0
      }
    },
    {
      "id": "gcd_blank_range",
      "formula": "=GCD(A1:C1)",
      "setup": {},
      "expect": {
        "kind": "number",
        "value": 0.0
      }
    },
    {
      "id": "lcm_blank_range",
      "formula": "=LCM(A1:C1)",
      "setup": {},
      "expect": {
        "kind": "number",
        "value": 0.0
      }
    },
    {
      "id": "offset_neg_height",
      "formula": "=OFFSET(A1,2,2,-10,1)",
      "setup": {
        "A1": {
          "kind": "number",
          "value": 1.0
        }
      },
      "expect": {
