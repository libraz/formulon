{
  "suite": "countif",
  "description": "COUNTIF / SUMIF / AVERAGEIF criteria engine",
  "environment": {
    "excel_version": "16.108.1",
    "excel_locale": "ja-JP",
    "date1904": false,
    "iterative": false,
    "generated_at": "2026-04-23T01:57:45Z"
  },
  "tolerance": {
    "abs": 1e-12,
    "rel": 1e-12
  },
  "cases": [
    {
      "id": "countif_number_equality",
      "formula": "=COUNTIF(A1:A3,10)",
      "setup": {
        "A1": {
          "kind": "number",
          "value": 10.0
        },
        "A2": {
          "kind": "number",
          "value": 20.0
        },
        "A3": {
          "kind": "number",
          "value": 10.0
        }
      },
      "expect": {
        "kind": "number",
        "value": 2.0
      }
    },
    {
      "id": "countif_explicit_gt",
      "formula": "=COUNTIF(A1:A3,\">15\")",
      "setup": {
        "A1": {
          "kind": "number",
          "value": 10.0
        },
        "A2": {
          "kind": "number",
          "value": 20.0
        },
        "A3": {
          "kind": "number",
          "value": 30.0
        }
      },
      "expect": {
        "kind": "number",
        "value": 2.0
      }
    },
    {
      "id": "countif_explicit_ne",
      "formula": "=COUNTIF(A1:A3,\"<>10\")",
      "setup": {
        "A1": {
          "kind": "number",
          "value": 10.0
        },
        "A2": {
          "kind": "number",
          "value": 20.0
        },
        "A3": {
          "kind": "number",
          "value": 10.0
        }
      },
      "expect": {
        "kind": "number",
        "value": 1.0
      }
    },
    {
      "id": "countif_text_exact",
      "formula": "=COUNTIF(A1:A3,\"apple\")",
      "setup": {
        "A1": {
          "kind": "text",
          "value": "apple"
        },
        "A2": {
          "kind": "text",
          "value": "banana"
        },
        "A3": {
          "kind": "text",
          "value": "apple"
        }
      },
      "expect": {
        "kind": "number",
        "value": 2.0
      }
    },
    {
      "id": "countif_wildcard_star",
      "formula": "=COUNTIF(A1:A3,\"app*\")",
      "setup": {
        "A1": {
          "kind": "text",
          "value": "apple"
        },
        "A2": {
          "kind": "text",
          "value": "application"
        },
        "A3": {
          "kind": "text",
          "value": "banana"
        }
      },
      "expect": {
        "kind": "number",
        "value": 2.0
      }
    },
    {
      "id": "countif_wildcard_q",
      "formula": "=COUNTIF(A1:A3,\"c?t\")",
      "setup": {
        "A1": {
          "kind": "text",
          "value": "cat"
        },
        "A2": {
          "kind": "text",
          "value": "cut"
        },
        "A3": {
          "kind": "text",
          "value": "cart"
        }
      },
      "expect": {
        "kind": "number",
        "value": 2.0
      }
    },
    {
      "id": "countif_tilde_escapes_star",
      "formula": "=COUNTIF(A1:A3,\"a~*?\")",
      "setup": {
        "A1": {
          "kind": "text",
          "value": "a*b"
        },
        "A2": {
          "kind": "text",
          "value": "ab"
        },
        "A3": {
          "kind": "text",
          "value": "a*c"
        }
      },
      "expect": {
        "kind": "number",
        "value": 2.0
      }
    },
    {
      "id": "sumif_numeric_gt",
      "formula": "=SUMIF(A1:A3,\">15\")",
      "setup": {
        "A1": {
          "kind": "number",
          "value": 10.0
        },
        "A2": {
          "kind": "number",
          "value": 20.0
        },
        "A3": {
          "kind": "number",
          "value": 30.0
        }
      },
      "expect": {
        "kind": "number",
        "value": 50.0
      }
    },
    {
      "id": "sumif_with_sum_range",
      "formula": "=SUMIF(A1:A3,\"x\",B1:B3)",
      "setup": {
        "A1": {
          "kind": "text",
          "value": "x"
        },
        "A2": {
          "kind": "text",
          "value": "y"
        },
        "A3": {
          "kind": "text",
          "value": "x"
        },
        "B1": {
          "kind": "number",
          "value": 1.0
        },
        "B2": {
          "kind": "number",
          "value": 2.0
        },
        "B3": {
          "kind": "number",
          "value": 3.0
        }
      },
      "expect": {
        "kind": "number",
        "value": 4.0
      }
    },
    {
      "id": "averageif_numeric_gt",
      "formula": "=AVERAGEIF(A1:A3,\">15\")",
      "setup": {
        "A1": {
          "kind": "number",
          "value": 10.0
        },
        "A2": {
          "kind": "number",
          "value": 20.0
        },
        "A3": {
          "kind": "number",
          "value": 30.0
        }
      },
      "expect": {
        "kind": "number",
        "value": 25.0
      }
    },
    {
      "id": "averageif_no_match_returns_div0",
      "formula": "=AVERAGEIF(A1:A3,\">100\")",
      "setup": {
        "A1": {
          "kind": "number",
          "value": 10.0
        },
        "A2": {
          "kind": "number",
          "value": 20.0
        },
        "A3": {
          "kind": "number",
          "value": 30.0
        }
      },
      "expect": {
        "kind": "error",
        "code": "#DIV/0!"
      }
    }
  ]
}
