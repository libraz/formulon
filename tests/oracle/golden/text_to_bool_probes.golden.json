{
  "suite": "text_to_bool_probes",
  "description": "Mac Excel 365 (ja-JP) probe for whether text strings \"TRUE\"/\"true\"/ \"FALSE\"/\"false\" coerce to bool when passed to a function argument that expects a logical value. IronCalc accepts these strings (e.g. BETA.DIST(..., \"TRUE\", ...)), but Formulon's `coerce_to_bool` currently rejects them and surfaces #VALUE! — based on a comment that claims Excel does the same. This probe settles the question by asking Mac directly across IF, NOT, AND, BETA.DIST cumulative, and direct coercion via N(). Mac's truth becomes the reference; we update `coerce_to_bool` only if Mac actually accepts these strings.\n",
  "environment": {
    "excel_version": "16.108.1",
    "excel_locale": "ja-JP",
    "date1904": false,
    "iterative": false,
    "generated_at": "2026-04-26T10:32:35Z"
  },
  "tolerance": {
    "abs": 1e-12,
    "rel": 0.0
  },
  "cases": [
    {
      "id": "text_bool_if_uppercase_true",
      "formula": "=IF(\"TRUE\", 1, 0)",
      "setup": {},
      "expect": {
        "kind": "number",
        "value": 1.0
      }
    },
    {
      "id": "text_bool_if_lowercase_true",
      "formula": "=IF(\"true\", 1, 0)",
      "setup": {},
      "expect": {
        "kind": "number",
        "value": 1.0
      }
    },
    {
      "id": "text_bool_if_uppercase_false",
      "formula": "=IF(\"FALSE\", 1, 0)",
      "setup": {},
      "expect": {
        "kind": "number",
        "value": 0.0
      }
    },
    {
      "id": "text_bool_if_mixed_case",
      "formula": "=IF(\"True\", 1, 0)",
      "setup": {},
      "expect": {
        "kind": "number",
        "value": 1.0
      }
    },
    {
      "id": "text_bool_if_garbage",
      "formula": "=IF(\"yes\", 1, 0)",
      "setup": {},
      "expect": {
        "kind": "error",
        "code": "#VALUE!"
      }
    },
    {
      "id": "text_bool_not_uppercase_true",
      "formula": "=NOT(\"TRUE\")",
      "setup": {},
      "expect": {
        "kind": "bool",
        "value": false
      }
    },
    {
      "id": "text_bool_not_lowercase_false",
      "formula": "=NOT(\"false\")",
      "setup": {},
      "expect": {
        "kind": "bool",
        "value": true
      }
    },
    {
      "id": "text_bool_and_two_true",
      "formula": "=AND(\"TRUE\", \"TRUE\")",
      "setup": {},
      "expect": {
        "kind": "bool",
        "value": true
      }
    },
    {
      "id": "text_bool_and_true_false",
      "formula": "=AND(\"TRUE\", \"FALSE\")",
      "setup": {},
      "expect": {
        "kind": "bool",
        "value": false
      }
    },
    {
      "id": "text_bool_and_whitespace",
      "formula": "=AND(\"  TRUE  \", TRUE)",
      "setup": {},
      "expect": {
        "kind": "bool",
        "value": true
      }
    },
    {
      "id": "text_bool_or_whitespace",
      "formula": "=OR(\"  FALSE  \", FALSE)",
      "setup": {},
      "expect": {
        "kind": "bool",
        "value": false
      }
    },
    {
      "id": "text_bool_betadist_uppercase",
      "formula": "=BETA.DIST(0.234, 2, 2.5, \"TRUE\", 0.15, 1.2)",
      "setup": {},
      "expect": {
        "kind": "number",
        "value": 0.02579396768034742
      }
    },
